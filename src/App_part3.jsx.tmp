
  const handleNav = (tab) => {
    setActiveTab(tab);
    // Smooth scroll to top when changing tabs (Mobile stability fix)
    if (scrollRef.current) {
      scrollRef.current.scrollTo({ top: 0, behavior: 'instant' });
    }
  };

  const partnerLabel = userRole === 'husband' ? '아내' : '남편';

  return (
    <div 
      className="app-master-container" 
      ref={scrollRef}
      style={{ 
        width: '100%', 
        height: '100dvh', 
        overflowY: 'auto', 
        backgroundColor: '#FDFCF0',
        position: 'relative'
      }}
    >
      <AnimatePresence mode="wait">
        {view === 'splash' && <SplashView key="splash" onFinish={() => setView('login')} />}
        {view === 'login' && <LoginView key="login" onLogin={(u) => { setUser(u); loadUserProfile(u); }} />}
        {view === 'onboarding' && (
          <OnboardingView 
            key="onboarding" user={user} userRole={userRole} setUserRole={setUserRole} 
            onFinish={(inf) => { setView('home'); syncCoupleData(inf.coupleCode); }} 
          />
        )}
        
        {view === 'home' && (
          <>
            <main style={{ paddingBottom: '90px' }}>
              {activeTab === 'home' && (
                <HomeView 
                  key="home-main" 
                  user={user} userRole={userRole} 
                  husbandInfo={husbandInfo} wifeInfo={wifeInfo}
                  onNav={handleNav}
                  onOpenNotifications={() => setShowNotificationList(true)}
                />
              )}
              
              {activeTab === 'cardGame' && (
                <CardGameView 
                  key="cardGame" 
                  onBack={() => setActiveTab('home')}
                  userRole={userRole}
                  coupleCode={coupleCode}
                />
              )}

              {activeTab === 'counseling' && (
                <div style={{ padding: '20px' }}>
                   {/* Inlined or imported Counseling view logic from bak */}
                   <div style={{ textAlign: 'center', padding: '100px 20px' }}>
                      <Sparkles size={48} color="#8A60FF" style={{ margin: '0 auto 20px' }} />
                      <h2 style={{ fontSize: '20px', fontWeight: 900 }}>AI 하티 준비 중</h2>
                      <p style={{ color: '#8B7355', marginTop: '10px' }}>더 정교한 부부 상담을 위해 학습 중입니다.</p>
                   </div>
                </div>
              )}

              {activeTab === 'worship' && (
                <div style={{ padding: '20px' }}>
                   <BookOpen size={48} color="#D4AF37" style={{ margin: '40px auto 20px' }} />
                   <h2 style={{ textAlign: 'center', fontWeight: 900 }}>가정 예배</h2>
                   <p style={{ textAlign: 'center', color: '#8B7355' }}>준비 중인 기능입니다.</p>
                </div>
              )}

              {activeTab === 'heartPrayer' && (
                 <IntimacyGarden 
                   onBack={() => setActiveTab('home')} 
                   user={user} userRole={userRole} 
                   husbandInfo={husbandInfo} wifeInfo={wifeInfo} coupleCode={coupleCode} 
                 />
              )}

              {activeTab === 'settings' && (
                <SettingsView 
                  user={user} userRole={userRole} 
                  husbandInfo={husbandInfo} setHusbandInfo={setHusbandInfo}
                  wifeInfo={wifeInfo} setWifeInfo={setWifeInfo}
                  coupleCode={coupleCode}
                  onNav={handleNav}
                  onLogout={handleLogout}
                />
              )}
            </main>

            {/* 💎 RESTORED Bottom Nav Bar - All buttons are back! */}
            <nav className="bottom-nav">
              <NavItem active={activeTab === 'home'} onClick={() => handleNav('home')} icon={<Home size={22} />} label="홈" />
              <NavItem active={activeTab === 'cardGame'} onClick={() => handleNav('cardGame')} icon={<MessageSquare size={22} />} label="대화카드" />
              <NavItem active={activeTab === 'counseling'} onClick={() => handleNav('counseling')} icon={<Sparkles size={22} />} label="AI하티" />
              <NavItem active={activeTab === 'worship'} onClick={() => handleNav('worship')} icon={<BookOpen size={22} />} label="가정예배" />
              <NavItem active={activeTab === 'heartPrayer'} onClick={() => handleNav('heartPrayer')} icon={<Heart size={22} />} label="작은숲" />
            </nav>
          </>
        )}
      </AnimatePresence>
    </div>
  );
};

export default App;
